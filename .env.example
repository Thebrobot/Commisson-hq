# Frontend (Vite) - used by src/lib/supabase.ts
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Production site URL (no trailing slash). Use on Vercel for BOTH client build and serverless:
# - Sign-up confirmation emails use VITE_APP_URL (embedded at build time in Login.tsx)
# - Rep invite emails use APP_URL (server) or VITE_APP_URL / VERCEL_URL; see api/invite-rep.ts
# VITE_APP_URL=https://your-production-domain.vercel.app
# APP_URL=https://your-production-domain.vercel.app

# Serverless API (Vercel) - signup-complete, invite-rep, webhook
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
